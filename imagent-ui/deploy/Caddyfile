subnets.giize.com {
	encode zstd gzip
	reverse_proxy 127.0.0.1:8765
}

dlcourse.gleeze.com {
	encode zstd gzip
	reverse_proxy 127.0.0.1:8080
}

http://tryimagent.com {
	redir https://tryimagent.com{uri} permanent
}

http://www.tryimagent.com {
	redir https://tryimagent.com{uri} permanent
}

https://www.tryimagent.com {
	redir https://tryimagent.com{uri} permanent
}

https://tryimagent.com {
	encode zstd gzip

	# Defense-in-depth security headers, mirrored from next.config.mjs so they
	# apply even to responses Caddy serves directly.
	header {
		Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
		Content-Security-Policy "default-src 'self'; base-uri 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://github.com https://*.githubusercontent.com; font-src 'self'; connect-src 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		X-Frame-Options "DENY"
		-Server
	}

	# The Next.js server MUST bind to loopback (127.0.0.1) only. If it listens on
	# a public interface, the unauthenticated /api routes (generate, verify) can
	# be reached directly, bypassing Caddy's TLS, headers, and rate limiting.
	reverse_proxy 127.0.0.1:3002
}
