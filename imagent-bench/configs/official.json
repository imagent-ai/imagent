{
  "benchmark_version": "official-v1",
  "dataset_version": "official-v1.0.0",
  "suite": "official_v1",
  "agent_config": {
    "runtime": {
      "max_feedback_rounds": 1
    },
    "agent": {
      "image_backend": {
        "mode": "live",
        "provider": "openrouter",
        "api_key_env": "OPENROUTER_API_KEY",
        "endpoint": "https://openrouter.ai/api/v1/images",
        "model": "google/gemini-3.1-flash-image",
        "resolution": "1K",
        "aspect_ratio": "1:1",
        "output_format": "png",
        "send_seed": false,
        "send_output_format": false,
        "timeout_seconds": 240,
        "referer": "https://tryimagent.com",
        "title": "imagent official benchmark"
      },
      "verifier": {
        "provider": "openrouter_vision",
        "api_key_env": "OPENROUTER_API_KEY",
        "model": "google/gemini-2.5-flash",
        "timeout_seconds": 180,
        "referer": "https://tryimagent.com",
        "title": "imagent official verifier"
      }
    },
    "evaluation": {
      "image_judge": {
        "provider": "openrouter_vision",
        "api_key_env": "OPENROUTER_API_KEY",
        "model": "google/gemini-2.5-flash",
        "rubric_version": "openrouter-vision-v1",
        "temperature": 0,
        "max_tokens": 1200,
        "timeout_seconds": 180,
        "referer": "https://tryimagent.com",
        "title": "imagent official judge"
      }
    }
  },
  "execution": {
    "install": false
  },
  "policy": {
    "minimum_score": 100.0,
    "max_failed_cases": 0,
    "max_cost_usd": 999.0,
    "max_latency_p95_ms": 30000.0
  }
}
